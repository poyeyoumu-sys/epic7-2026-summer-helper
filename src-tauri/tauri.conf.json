{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "2026夏活辅助",
  "version": "1.0.0",
  "identifier": "com.epic7.summerhelper2026",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "2026夏活辅助",
        "width": 1480,
        "height": 860,
        "minWidth": 1180,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/128x128.png", "icons/icon.ico"],
    "resources": [
      "resources/config/**/*",
      "resources/templates/**/*",
      "resources/tools/**/*",
      "runtime/maa/**/*"
    ]
  }
}
